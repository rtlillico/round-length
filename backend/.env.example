# round-length/backend/.env.example
# Copy this to .env and fill in your values.
# Never commit .env to git.

# Server
PORT=3000
FRONTEND_URL=http://localhost:5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roundlength
DB_USER=roundlength
DB_PASSWORD=choose_a_strong_password_here

# SILO — your email address used for SILO API calls
# No registration required, just a valid email
SILO_EMAIL=your@email.com

# Admin secret — used to manually trigger the nightly update via API
# Choose any random string
ADMIN_SECRET=choose_a_random_string_here

# BOM IFD data — path to the directory containing the 1°x1° IFD ZIP files
# When set, IFD runoff data is extracted automatically when a farm is created or moved.
# Leave blank to skip IFD extraction (runoff model will not apply location-specific thresholds).
IFD_ZIP_DIR=/var/www/round-length/ifd_zips

# Python interpreter to use for IFD extraction (default: python3)
# IFD_PYTHON=python3
